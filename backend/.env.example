# Application
APP_NAME=AI Avatar API
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg://avatar:avatar_dev_password@localhost:5433/avatar_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# OpenAI (required from Phase 4+)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE_EN=alloy
OPENAI_TTS_VOICE_AR=nova
HEYGEN_API_KEY=
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.55
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# File storage
FILE_STORAGE_PATH=./uploads
MAX_UPLOAD_SIZE_MB=50

# Celery (set true in tests to run tasks inline without worker)
CELERY_TASK_ALWAYS_EAGER=false

# Scraper
SCRAPER_USE_PLAYWRIGHT=false
SCRAPER_TIMEOUT_SECONDS=30
